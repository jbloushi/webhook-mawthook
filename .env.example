# Database — MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://mawthook:CHANGE_ME@localhost:3306/mawthook"

# Security — generate each with: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
# Or let the setup wizard generate them automatically (recommended)
ENCRYPTION_KEY=""
JWT_SECRET=""

# Public URL where this app is reachable (no trailing slash)
APP_URL="https://webhook.yourdomain.com"

# Chatwoot integration (optional)
CHATWOOT_WEBHOOK_SECRET=""
CHATWOOT_BASE_URL=""
CHATWOOT_API_TOKEN=""
CHATWOOT_ACCOUNT_ID=""
