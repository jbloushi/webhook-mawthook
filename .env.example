# Database (native/local PostgreSQL)
# If your DB password has special characters (@ : / ? #), URL-encode it in DATABASE_URL.
DATABASE_URL="postgresql://mawthook:CHANGE_ME@127.0.0.1:5432/mawthook?schema=public"
DB_PASSWORD="CHANGE_ME"

# Security — generate each with: openssl rand -hex 32
ENCRYPTION_KEY=""
JWT_SECRET=""

# Public URL where this app is reachable (no trailing slash)
APP_URL="https://webhook.yourdomain.com"

# Chatwoot webhook shared secret (any random string)
CHATWOOT_WEBHOOK_SECRET=""

# Optional: WhatsApp credentials (can also be added via dashboard)
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_ACCESS_TOKEN=""
